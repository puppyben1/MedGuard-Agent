# Groq (required) — free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LLM models (defaults shown — no need to change)
ROUTER_MODEL=llama-3.1-8b-instant
GENERATOR_MODEL=llama-3.3-70b-versatile

# ChromaDB persist directory
CHROMA_PERSIST_DIR=./data/chromadb

# BM25 persist directory
BM25_PERSIST_DIR=./data/bm25

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Retrieval settings
HYBRID_SEARCH_TOP_K=20
RERANK_TOP_K=10
MIN_RELEVANT_DOCS=3
MAX_REWRITE_RETRIES=2

# Langfuse observability (optional — self-hosted)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# openFDA adverse events API key (optional — higher rate limits)
OPENFDA_API_KEY=
